{"timestamp": "2026-03-24T03:53:30.454001+00:00", "level": "INFO", "logger": "text2sql", "message": "SQL generated", "request_id": "a4826308-3d0a-4647-97a9-51d1fb46b3b5", "stage": "sql_generation", "status": "ok", "duration_ms": 1515.63, "raw_sql": "SELECT \n  COUNT(order_id) AS total_orders,\n  COUNT(CASE WHEN LOWER(status) = 'cancelled' THEN 1 END) AS cancelled_orders,\n  CASE \n    WHEN COUNT(order_id) = 0 THEN 0\n    ELSE COUNT(CASE WHEN LOWER(status) = 'cancelled' THEN 1 END)::decimal / COUNT(order_id) * 100\n  END AS cancelled_percentage\nFROM orders;"}
